% config.sty
%
% Estilo personalizado para artigos do ENMC
%
% Este arquivo centraliza configurações de:
%   - pacotes utilizados
%   - formatação de título e autores
%   - estilo de seções
%   - resumo e palavras-chave
%   - margens e layout da página
%
% Objetivo: garantir padronização visual dos artigos.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PACOTES UTILIZADOS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Figuras e cores
\usepackage{graphicx,color}

% Legendas compactas
\usepackage[small]{caption}

% Pacotes matemáticos
\usepackage{amsfonts}
\usepackage{amssymb}
\usepackage{amsmath}

% Indenta o primeiro parágrafo após títulos
\usepackage{indentfirst}

% Fonte Times
\usepackage{times}

% Codificação UTF-8
\usepackage[utf8]{inputenc}

% Controle de espaçamento entre linhas
\usepackage{setspace}

% Ferramentas auxiliares para manipulação de comandos
\usepackage{etoolbox}

% Controle de layout da página
\usepackage{geometry}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% FORMATAÇÃO DO TÍTULO DO ARTIGO
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Redefinição completa do comando \maketitle
% Ajusta posicionamento do título e formatação de autores
\renewcommand\maketitle{\par
  \begingroup
    % Usa símbolos (*, †, ‡...) para notas de rodapé do título
    \renewcommand\thefootnote{\fnsymbol{footnote}}%

    % Define aparência da marca da nota
    \def\@makefnmark{\hbox to\z@{$\m@th^{\@thefnmark}$\hss}}%

    % Define o formato do texto da nota
    \long\def\@makefntext##1{\parindent 1em\noindent
            \hbox to1.8em{\hss$\m@th^{\@thefnmark}$}##1}%

    % Tratamento para documentos em duas colunas
    \if@twocolumn
      \ifnum \col@number=\@ne
        \@maketitle
      \else
        \twocolumn[\@maketitle]%
      \fi
    \else
      % Força nova página antes do título
      \newpage
      % Impede figuras no topo da página
      \global\@topnum\z@
      \@maketitle
    \fi

    \thispagestyle{plain}
    \@thanks

  \endgroup

  % Limpeza de contadores e macros
  \setcounter{footnote}{0}%
  \let\thanks\relax
  \let\maketitle\relax
  \let\@maketitle\relax
  \gdef\@thanks{}
  \gdef\@author{}
  \gdef\@title{}
}

% Estrutura visual do bloco de título
\def\@maketitle{%
  \newpage
  \null
  % Ajuste vertical fino do título
  \vspace{-0.68cm}

  % Espaçamento superior do título
  % (valor original era 50mm, alterado para 0mm)
  \vskip 0mm

  \begin{center}
    {\bfseries \@title}
  \end{center}

  \vskip 3.9bp

  % Autores
  {\noindent \bfseries \@author}

  \vskip 24bp
}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% FORMATAÇÃO DE SEÇÕES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Largura do rótulo da seção
\newlength{\seclabelwidth}

% Ajusta alinhamento do número das seções
\renewcommand{\@seccntformat}[1]{%
  \settowidth{\seclabelwidth}{\csname the#1\endcsname}%
  \addtolength{\seclabelwidth}{-0.75cm}%
  \csname the#1\endcsname\hspace{-\seclabelwidth}
}

% Profundidade máxima da numeração
\setcounter{secnumdepth}{2}

% Formato da numeração
\renewcommand\thesection{\arabic{section}.}
\renewcommand\thesubsection{\thesection\arabic{subsection}}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% ESTILO DOS TÍTULOS DE SEÇÃO
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\renewcommand\section{\@startsection
  {section}            % nome
  {1}                  % nível
  {0mm}                % indentação
  {4.7ex plus 1ex minus .2ex} % espaço antes
  {2.5ex plus .2ex}           % espaço depois
  {\reset@font\normalsize\bfseries} % estilo
}

\renewcommand\subsection{\@startsection
  {subsection}
  {2}
  {0mm}
  {2.5ex plus 1ex minus .2ex}
  {2.4ex plus .2ex}
  {\reset@font\normalsize\bfseries}
}

\renewcommand\subsubsection{\@startsection
  {subsubsection}
  {3}
  {0mm}
  {2.5ex plus 1ex minus .2ex}
  {-6bp} % texto continua na mesma linha
  {\reset@font\normalsize\bfseries}
}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% RESUMO E PALAVRAS-CHAVE
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Ambiente de resumo
\renewenvironment{abstract}{
    \noindent
    {\em \bfseries \abstractname.}
    \em
}{
    \endquotation
    \vskip 12bp
}

% Ambiente de palavras-chave
\newenvironment{keywords}{
    \noindent
    {\em \bfseries \keywordsname: }
    \rm
}{
    \endquotation
    \vskip 12bp
}

% Nome exibido para palavras-chave
\newcommand{\keywordsname}{Keywords}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CONFIGURAÇÃO DE PÁGINA
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Define tamanho do papel
\special{papersize=21cm,29.7cm}

% Margens do documento
\geometry{
    verbose,
    a4paper,
    lmargin = 2.5cm,
    rmargin = 2.5cm,
    tmargin = 2.5cm,
    bmargin = 3.1cm,
    headsep = 1.0cm
}

% Espaçamento antes das notas de rodapé
\setlength{\skip\footins}{1cm}


